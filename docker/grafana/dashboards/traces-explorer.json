{
  "uid": "autopr-traces",
  "title": "AutoPR — Traces & Latency Explorer",
  "tags": ["autopr", "traces"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "span",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(traces_spanmetrics_calls_total, span_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Span request rate — top 7 (by span)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(7, sum(rate(traces_spanmetrics_calls_total{span_name=~\"$span\"}[5m])) by (span_name))",
          "legendFormat": "{{span_name}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Span error rate (by span)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\", span_name=~\"$span\"}[5m])) by (span_name)",
          "legendFormat": "{{span_name}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Span latency p95 — top 7 slowest (by span)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(7, histogram_quantile(0.95, sum(rate(traces_spanmetrics_latency_bucket{span_name=~\"$span\"}[5m])) by (le, span_name)))",
          "legendFormat": "{{span_name}}", "exemplar": true }
      ]
    },
    {
      "id": 4,
      "type": "nodeGraph",
      "title": "Service graph",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "serviceMap" }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Slowest recent traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql", "query": "{ duration > 500ms }", "limit": 20, "tableType": "traces" }
      ]
    }
  ]
}
