# AutoPR environment template
# Copy this file to .env for local development. Keep .env out of git.
# Blank values mean the feature stays disabled or uses the code default.

# --- App runtime ---
AUTOPR_ENV=local
AUTOPR_SERVICE_NAME=autopr-local
AUTOPR_INSTANCE_ID=
AUTOPR_LOG_LEVEL=INFO

# --- Local service URLs ---
# Docker Compose overrides these hostnames inside containers.
AUTOPR_REDIS_URL=redis://localhost:6379/0
AUTOPR_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
AUTOPR_DATABASE_ASYNC_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# --- GitHub webhook intake ---
# Set GITHUB_WEBHOOK_SECRET to the exact secret configured on the GitHub webhook.
# Leave it blank only for unsigned local webhook tests.
GITHUB_WEBHOOK_SECRET=
AUTOPR_WEBHOOK_RUN_ON_ISSUES=true
AUTOPR_WEBHOOK_MERGE_ON_APPROVAL=false
AUTOPR_WEBHOOK_QUEUE_KEY=autopr:webhook:queue
AUTOPR_WEBHOOK_PROCESSING_KEY=autopr:webhook:processing
AUTOPR_WEBHOOK_DLQ_KEY=autopr:webhook:dlq
AUTOPR_WEBHOOK_MAX_ATTEMPTS=5

# --- GitHub API and repository writes ---
# GITHUB_TOKEN or GH_TOKEN must have access to the target repository.
# Keep AUTOPR_EXECUTE_REMOTE_ACTIONS=false for local dry runs.
GITHUB_TOKEN=
GH_TOKEN=
AUTOPR_EXECUTE_REMOTE_ACTIONS=false
AUTOPR_REPOS_DIR=repos
AUTOPR_KEEP_QA_WORKSPACE=false
GIT_COMMITTER_NAME=AutoPR Bot
GIT_COMMITTER_EMAIL=autopr-bot@users.noreply.github.com

# --- Pipeline controls ---
AUTOPR_MAX_AUTONOMOUS_LOOPS=50
QA_MAX_RETRIES=1

# --- LLM gateway ---
# Provider values supported by infra/llm/client.py: ollama, openai, anthropic, google.
# Model names come from configs/llm_models.yaml.
AUTOPR_LLM_PROVIDER=ollama
AUTOPR_LLM_MODEL_NAME=qwen3-coder
LLM_MODELS_CONFIG_PATH=configs/llm_models.yaml

# Required when AUTOPR_LLM_PROVIDER points at the matching hosted provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- LLM gateway rate limiting ---
# Per-model RPM and concurrency caps come from configs/llm_models.yaml.
# When AUTOPR_REDIS_URL is set, limits apply across workers through Redis.
AUTOPR_LLM_RATE_WAIT_TIMEOUT_SEC=30
AUTOPR_LLM_RATE_POLL_SEC=0.05
AUTOPR_LLM_RATE_LEASE_SEC=900

# --- Observability ---
# Local Python runs stay on console/none. Docker Compose overrides these to otlp.
AUTOPR_LOG_EXPORTER=console
AUTOPR_TRACE_EXPORTER=none
AUTOPR_METRICS_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=localhost:14317
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=localhost:14317
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=localhost:14317

# --- Ray runtime ---
# Leave RAY_ADDRESS blank to start a local Ray runtime.
RAY_ADDRESS=
RAY_DASHBOARD_HOST=127.0.0.1
RAY_DASHBOARD_PORT=8265
RAY_INCLUDE_DASHBOARD=true

# --- Slack and human review ---
# Set SLACK_WEBHOOK_URL to a Slack incoming webhook URL before enabling notifications.
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_NEEDS_REVIEW=false
SLACK_NOTIFY_DLQ=false
SLACK_TIMEOUT_SEC=5

# Public URL used in Slack review buttons, for example an ngrok URL during local testing.
AUTOPR_PUBLIC_BASE_URL=http://localhost:8000

# Required for signed approve/disapprove review-action links.
REVIEW_ACTION_TOKEN_SECRET=
REVIEW_ACTION_TTL_SEC=604800
